{
  "name": "meshuttle",
  "version": "1.1.0",
  "private": false,
  "author": "集御",
  "description": "支持自建服务器、局域网托管和无固定主机设备组的跨设备临时投递箱",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiyu-nb/Meshuttle.git"
  },
  "homepage": "https://github.com/jiyu-nb/Meshuttle#readme",
  "bugs": {
    "url": "https://github.com/jiyu-nb/Meshuttle/issues"
  },
  "main": "main.js",
  "scripts": {
    "fetch:syncthing": "node ../tools/fetch-syncthing.mjs",
    "start": "electron .",
    "test": "node --test",
    "test:p2p": "node ../tools/test-p2p-cluster.js",
    "dist": "npm run dist:win",
    "dist:win": "electron-builder --win nsis --publish never",
    "dist:mac": "electron-builder --mac --universal --publish never"
  },
  "build": {
    "appId": "cn.jiyu.meshuttle",
    "productName": "织梭 Meshuttle",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "p2p/**/*"
    ],
    "extraResources": [
      {
        "from": "vendor/syncthing",
        "to": "syncthing",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "../LICENSE",
        "to": "LICENSE-MESHUTTLE.txt"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "executableName": "Meshuttle",
      "artifactName": "Meshuttle-Setup-${version}.${ext}",
      "legalTrademarks": "Copyright © 2026 集御"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities",
      "artifactName": "Meshuttle-${version}-macOS-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "织梭 Meshuttle",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "dependencies": {
    "meshuttle-server": "file:../server"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  }
}
